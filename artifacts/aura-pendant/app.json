{
  "expo": {
    "name": "Aura Pendant Pro",
    "slug": "aura-pendant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aura-pendant",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aurapendant.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Aura uses your location to include live GPS in SOS alerts.",
        "NSContactsUsageDescription": "Aura uses your contacts so you can add emergency contacts quickly.",
        "NSCameraUsageDescription": "Aura uses the camera for live safety capture and SOS media.",
        "NSMicrophoneUsageDescription": "Aura uses the microphone when recording safety videos.",
        "NSFaceIDUsageDescription": "Aura uses Face ID or biometrics to protect your app."
      }
    },
    "android": {
      "package": "com.aurapendant.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "POST_NOTIFICATIONS",
        "READ_CONTACTS",
        "RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-camera",
      "expo-location",
      "expo-contacts",
      "expo-local-authentication",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "fb9a2a14-8317-4c3c-b2c7-5f885c7220ad"
      }
    }
  }
}
